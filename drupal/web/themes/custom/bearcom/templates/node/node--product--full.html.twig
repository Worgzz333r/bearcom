{# Product — full page: hero + specs + paragraphs #}
<article class="product-page">

  {# Hero section #}
  <section class="product-hero">
    <div class="container">
      <div class="product-hero__inner">

        {# Gallery — left side #}
        <div class="product-hero__gallery">
          {% if node.field_images|length > 0 %}
            <div class="product-hero__main-image">
              {{ content.field_images }}
            </div>
          {% endif %}
        </div>

        {# Info — right side #}
        <div class="product-hero__info">
          {% if node.field_product_type.value %}
            <span class="product-hero__type">Product Type: {{ node.field_product_type.value }}</span>
          {% endif %}

          <h1 class="product-hero__title">{{ label }}{% if node.field_category.entity %} | {{ node.field_category.entity.name.value }}{% endif %}</h1>

          {% if node.field_short_description.value %}
            <div class="product-hero__description">{{ content.field_short_description }}</div>
          {% endif %}

          {% if node.field_resources|length > 0 %}
            <div class="product-hero__resources">
              {% for item in node.field_resources %}
                <a href="{{ file_url(item.entity.uri.value) }}" target="_blank">{{ item.description|default(item.entity.filename.value) }}</a>
              {% endfor %}
            </div>
          {% endif %}

          {% if node.field_cta_url.0.url %}
            <div class="product-hero__cta">
              <a href="{{ node.field_cta_url.0.url.toString() }}" class="btn btn--primary">
                {{ node.field_cta_url.0.title|default('Request a Quote') }}
              </a>
            </div>
          {% endif %}
        </div>

      </div>
    </div>
  </section>

  {# Specs section #}
  {% if content.field_specs|render|trim %}
    <section class="product-specs">
      <div class="container">
        {{ content.field_specs }}
      </div>
    </section>
  {% endif %}

  {# Flexible paragraphs #}
  {% if content.field_paragraphs|render|trim %}
    {{ content.field_paragraphs }}
  {% endif %}

</article>
