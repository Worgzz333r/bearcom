{#
/**
 * @file
 * Location Detail Page — individual office/branch.
 * Hero style controlled via field_hero_style (orange/grey).
 */
#}

{% set hero_style = node.field_hero_style.value|default('orange') %}

<article{{ attributes.addClass('location-detail', 'location-detail--' ~ hero_style) }}>

  {# Hero #}
  <section class="location-detail__hero location-detail__hero--{{ hero_style }}">
    <div class="container">
      <h1 class="location-detail__hero-title">{{ label }}</h1>
      {% if content.field_description|render|trim %}
        <div class="location-detail__hero-desc">{{ content.field_description }}</div>
      {% endif %}
      <div class="location-detail__hero-buttons">
        <a href="/contact-us" class="btn btn--white">CTA Button</a>
        {% if node.field_phone.value %}
          <a href="tel:{{ node.field_phone.value }}" class="btn location-detail__hero-phone">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17.0734 12.9334V15.4334C17.0744 15.6655 17.0268 15.8952 16.9339 16.1079C16.8409 16.3205 16.7045 16.5114 16.5335 16.6683C16.3625 16.8252 16.1606 16.9446 15.9407 17.019C15.7209 17.0934 15.4879 17.121 15.2568 17.1001C12.6925 16.8214 10.2293 15.9452 8.0651 14.5417C6.05162 13.2623 4.34454 11.5552 3.0651 9.54175C1.65675 7.36775 0.7803 4.89258 0.506764 2.31675C0.485939 2.0863 0.513326 1.85405 0.587181 1.63477C0.661035 1.41549 0.77974 1.21399 0.935736 1.0431C1.09173 0.872208 1.2816 0.735672 1.49326 0.642182C1.70491 0.548693 1.93371 0.500299 2.1651 0.500081H4.6651C5.06952 0.4961 5.46159 0.639313 5.76823 0.903025C6.07487 1.16674 6.27516 1.53295 6.33176 1.93341C6.43728 2.73347 6.63297 3.51902 6.9151 4.27508C7.02722 4.57335 7.05148 4.89751 6.98502 5.20915C6.91856 5.52079 6.76415 5.80684 6.5401 6.03341L5.48176 7.09175C6.66806 9.17804 8.39548 10.9055 10.4818 12.0917L11.5401 11.0334C11.7667 10.8094 12.0527 10.655 12.3644 10.5885C12.676 10.522 13.0002 10.5463 13.2984 10.6584C14.0545 10.9405 14.84 11.1362 15.6401 11.2417C16.0449 11.2989 16.4146 11.5028 16.6789 11.8147C16.9432 12.1266 17.0836 12.5247 17.0734 12.9334Z" stroke="#EFEFEF" stroke-linecap="round" stroke-linejoin="round"/></svg>
            ({{ node.field_phone.value[:3] }}) {{ node.field_phone.value[4:] }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>

  {# Info + Photo #}
  <section class="location-detail__info">
    <div class="container">
      <div class="location-detail__info-layout">
        <div class="location-detail__info-left">
          {% if node.field_address.value %}
            <h2 class="location-detail__office-name">{{ node.field_address.value|split("\n")|first }}</h2>
            {% set address_lines = node.field_address.value|split("\n") %}
            {% if address_lines|length > 1 %}
              <div class="location-detail__address">{{ address_lines|slice(1)|join('<br>')|raw }}</div>
            {% endif %}
          {% endif %}

          {% if node.field_phone.value %}
            <div class="location-detail__phone">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17.0734 12.9334V15.4334C17.0744 15.6655 17.0268 15.8952 16.9339 16.1079C16.8409 16.3205 16.7045 16.5114 16.5335 16.6683C16.3625 16.8252 16.1606 16.9446 15.9407 17.019C15.7209 17.0934 15.4879 17.121 15.2568 17.1001C12.6925 16.8214 10.2293 15.9452 8.0651 14.5417C6.05162 13.2623 4.34454 11.5552 3.0651 9.54175C1.65675 7.36775 0.7803 4.89258 0.506764 2.31675C0.485939 2.0863 0.513326 1.85405 0.587181 1.63477C0.661035 1.41549 0.77974 1.21399 0.935736 1.0431C1.09173 0.872208 1.2816 0.735672 1.49326 0.642182C1.70491 0.548693 1.93371 0.500299 2.1651 0.500081H4.6651C5.06952 0.4961 5.46159 0.639313 5.76823 0.903025C6.07487 1.16674 6.27516 1.53295 6.33176 1.93341C6.43728 2.73347 6.63297 3.51902 6.9151 4.27508C7.02722 4.57335 7.05148 4.89751 6.98502 5.20915C6.91856 5.52079 6.76415 5.80684 6.5401 6.03341L5.48176 7.09175C6.66806 9.17804 8.39548 10.9055 10.4818 12.0917L11.5401 11.0334C11.7667 10.8094 12.0527 10.655 12.3644 10.5885C12.676 10.522 13.0002 10.5463 13.2984 10.6584C14.0545 10.9405 14.84 11.1362 15.6401 11.2417C16.0449 11.2989 16.4146 11.5028 16.6789 11.8147C16.9432 12.1266 17.0836 12.5247 17.0734 12.9334Z" stroke="#4A4F55" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <a href="tel:{{ node.field_phone.value }}">({{ node.field_phone.value[:3] }}) {{ node.field_phone.value[4:] }}</a>
            </div>
          {% endif %}

          <div class="location-detail__divider"></div>

          {# Open Hours #}
          {% if content.field_open_hours|render|trim %}
            <div class="location-detail__hours">
              <h3 class="location-detail__hours-title">Open Hours</h3>
              <table class="location-detail__hours-table">
                <tbody>
                  {% for item in node.field_open_hours %}
                    {% set row = item.entity %}
                    <tr>
                      <td class="location-detail__hours-day">{{ row.field_day.value }}</td>
                      <td class="location-detail__hours-time">{{ row.field_hours.value }}</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% endif %}
        </div>

        <div class="location-detail__info-right">
          {% if node.field_photo.entity %}
            {% set media = node.field_photo.entity %}
            {% set image = media.field_media_image.entity %}
            {% if image %}
              <div class="location-detail__photo">
                <img src="{{ file_url(image.uri.value) }}" alt="{{ media.field_media_image.alt }}" loading="lazy">
              </div>
            {% endif %}
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  {# About #}
  {% if node.field_about.value %}
    <section class="location-detail__about">
      <div class="container">
        <div class="location-detail__about-layout">
          <div class="location-detail__about-text">
            <h2 class="location-detail__about-title">About the Office</h2>
            <div class="location-detail__about-body">{{ node.field_about.value|raw }}</div>
          </div>
          <div class="location-detail__about-wave" aria-hidden="true">
            {{ source('@bearcom/images/soundwave.svg')|raw }}
          </div>
        </div>
      </div>
    </section>
  {% endif %}

  {# FAQ (rendered via faq_two_column paragraph) #}
  {% if content.field_faq|render|trim %}
    {{ content.field_faq }}
  {% endif %}

  {# CTA #}
  {% if content.field_cta|render|trim %}
    <section class="location-detail__cta">
      {{ content.field_cta }}
    </section>
  {% endif %}

</article>
