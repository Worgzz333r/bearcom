{#
/**
 * Landing Page — Paid Search LP with minimal header, form + benefits.
 */
#}
<article class="landing-page">

  {# Soundwave icon #}
  <div class="landing-page__icon">
    <img src="/{{ directory }}/images/soundwave.svg" alt="" width="80" height="50">
  </div>

  {# Main content — two columns #}
  <section class="landing-page__main">
    <div class="container">
      <div class="landing-page__grid">

        {# Left column — text + benefits + image #}
        <div class="landing-page__info">
          {% if node.field_headline.value %}
            <h1 class="landing-page__headline">{{ node.field_headline.value }}</h1>
          {% endif %}

          {% if node.field_description.value %}
            <div class="landing-page__desc">{{ content.field_description }}</div>
          {% endif %}

          {% if content.field_benefits|render|trim %}
            <div class="landing-page__benefits">
              {{ content.field_benefits }}
            </div>
          {% endif %}

          {% if node.field_image.entity %}
            <div class="landing-page__image">
              <img src="{{ file_url(node.field_image.entity.uri.value) }}" alt="{{ node.field_image.alt }}" loading="lazy">
            </div>
          {% endif %}
        </div>

        {# Right column — webform #}
        <div class="landing-page__form">
          <h2 class="landing-page__form-title">Just a few details first</h2>
          {% if content.field_webform|render|trim %}
            {{ content.field_webform }}
          {% endif %}
        </div>

      </div>
    </div>
  </section>

  {# CTA Block #}
  {% if content.field_cta|render|trim %}
    {{ content.field_cta }}
  {% endif %}

</article>
