{# Article — full page: v1 (image hero) / v2 (blue hero) #}
{% set hero_style = node.field_hero_style.value|default('image') %}
{% set show_share = node.field_show_share.value %}

<article class="article-page article-page--{{ hero_style }}">

  {# Hero #}
  <section class="article-hero article-hero--{{ hero_style }}">
    {% if hero_style == 'image' and node.field_image.entity %}
      <div class="article-hero__bg" style="background-image: url('{{ file_url(node.field_image.entity.uri.value) }}');"></div>
    {% endif %}
    <div class="container">
      <div class="article-hero__content">
        {% if node.field_tags|length > 0 %}
          <div class="article-hero__tags">
            {% for tag in node.field_tags %}
              <span class="article-hero__tag">{{ tag.entity.name.value }}</span>
            {% endfor %}
          </div>
        {% endif %}
        <h1 class="article-hero__title">{{ label }}</h1>
        {% if node.getCreatedTime() %}
          <time class="article-hero__date" datetime="{{ node.getCreatedTime()|date('Y-m-d') }}">
            {{ node.getCreatedTime()|date('F j, Y') }}
          </time>
        {% endif %}
      </div>
    </div>
  </section>

  {# Body content #}
  <section class="article-body">
    <div class="container">
      <div class="article-body__inner">
        <div class="article-body__content">
          {{ content.body }}
        </div>

        {% if show_share %}
          <aside class="article-share">
            <span class="article-share__label">Share</span>
            <div class="article-share__buttons">
              <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ url('<current>')|url_encode }}&title={{ label|url_encode }}" target="_blank" rel="noopener" class="article-share__btn article-share__btn--linkedin" aria-label="Share on LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://twitter.com/intent/tweet?url={{ url('<current>')|url_encode }}&text={{ label|url_encode }}" target="_blank" rel="noopener" class="article-share__btn article-share__btn--twitter" aria-label="Share on X">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ url('<current>')|url_encode }}" target="_blank" rel="noopener" class="article-share__btn article-share__btn--facebook" aria-label="Share on Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="mailto:?subject={{ label|url_encode }}&body={{ url('<current>')|url_encode }}" class="article-share__btn article-share__btn--email" aria-label="Share via Email">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>
              </a>
            </div>
          </aside>
        {% endif %}
      </div>
    </div>
  </section>

  {# CTA Block #}
  {% if content.field_cta|render|trim %}
    {{ content.field_cta }}
  {% endif %}

  {# Related Articles #}
  {% if node.field_related|length > 0 %}
    <section class="article-related">
      <div class="container">
        <h2 class="article-related__title">Related Articles</h2>
        <div class="article-related__grid">
          {% for item in node.field_related %}
            {% set related_node = item.entity %}
            {% if related_node %}
              <a href="{{ path('entity.node.canonical', {'node': related_node.id()}) }}" class="article-related__card">
                {% if related_node.field_image.entity %}
                  <div class="article-related__card-image">
                    <img src="{{ file_url(related_node.field_image.entity.uri.value) }}" alt="{{ related_node.label() }}" loading="lazy">
                  </div>
                {% endif %}
                <div class="article-related__card-body">
                  <h3 class="article-related__card-title">{{ related_node.label() }}</h3>
                  <time class="article-related__card-date">{{ related_node.getCreatedTime()|date('F j, Y') }}</time>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

</article>
