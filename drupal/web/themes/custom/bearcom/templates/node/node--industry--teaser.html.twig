{#
/**
 * @file
 * Industry node — teaser view mode.
 * Used on /industries listing (View: industries_listing).
 */
#}

<article{{ attributes.addClass('industry-card') }}>

  {% if content.field_icon|render|trim %}
    <div class="industry-card__image">
      {{ content.field_icon }}
    </div>
  {% endif %}

  <div class="industry-card__body">
    <h3 class="industry-card__title">
      <a href="{{ url }}">{{ label }}</a>
    </h3>

    {% if content.field_description|render|trim %}
      <div class="industry-card__description">
        {{ content.field_description }}
      </div>
    {% endif %}

    <a href="{{ url }}" class="industry-card__link">Learn More</a>
  </div>

</article>
