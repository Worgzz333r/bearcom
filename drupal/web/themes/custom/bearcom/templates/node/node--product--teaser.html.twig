{#
/**
 * @file
 * Product node — teaser view mode.
 * Used on /products listing (View: products_listing).
 */
#}

<article{{ attributes.addClass('product-card') }}>
  <a href="{{ url }}" class="product-card__link">

    <div class="product-card__image">
      {% if node.field_images.0.entity and node.field_images.0.entity.field_media_image.entity %}
        <img src="{{ file_url(node.field_images.0.entity.field_media_image.entity.uri.value) }}"
             alt="{{ node.field_images.0.entity.field_media_image.alt }}"
             loading="lazy">
      {% endif %}
    </div>

    <div class="product-card__body">
      <div class="product-card__dashes"><span></span><span></span><span></span><span></span><span></span></div>
      <h3 class="product-card__title">{{ label }}</h3>

      {% if content.field_short_description|render|trim %}
        <div class="product-card__description">
          {{ content.field_short_description }}
        </div>
      {% endif %}
    </div>

  </a>
</article>
