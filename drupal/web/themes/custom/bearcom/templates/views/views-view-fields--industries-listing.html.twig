{#
/**
 * @file
 * View row: Industries Listing — fields mode.
 * Renders each industry as an industry-card.
 * view_node field renders as <a href="/path">Learn More</a>
 */
#}

<article class="industry-card">
  <div class="industry-card__image">
    {{ fields.field_icon.content }}
  </div>

  <div class="industry-card__body">
    <h3 class="industry-card__title">
      {{ fields.title.content }}
    </h3>

    <div class="industry-card__description">
      {{ fields.field_description.content }}
    </div>

    <div class="industry-card__link">
      {{ fields.view_node.content }}
    </div>
  </div>
</article>
