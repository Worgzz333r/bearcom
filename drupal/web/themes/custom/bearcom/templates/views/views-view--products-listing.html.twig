{#
/**
 * @file
 * View: Products Listing — /products
 * Sidebar filters + 3×3 product card grid with AJAX.
 * Embedded via product_grid paragraph on a flexible_page node.
 */
#}

{{ attach_library('bearcom/category') }}
{{ attach_library('bearcom/filter-sidebar') }}

{%
  set classes = [
    'category-page',
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{ attributes.addClass(classes) }}>
  <div class="container">

    {# Layout: sidebar + top bar + grid #}
    <div class="category-page__layout">

      {# Sidebar — exposed filters #}
      {% if exposed %}
        <aside class="filter-sidebar">
          <div class="filter-sidebar__label">
            Filter by:
            <button class="filter-sidebar__close" aria-label="Close filters">
              <img src="/{{ directory }}/images/cross.svg" alt="" width="24" height="24">
            </button>
          </div>
          {{ exposed }}
          <button type="button" class="filter-sidebar__clear">Clear All Filters</button>
        </aside>
      {% endif %}

      {# Main — top bar + product grid + pager #}
      <div class="category-page__main">
        <div class="category-page__top">
          <button class="filter-toggle" aria-controls="filter-sidebar" aria-expanded="false">
            <img class="filter-toggle__icon" src="/{{ directory }}/images/sliders-horizontal.svg" alt="" width="15" height="15">
            Filters
          </button>
          {% if header %}
            <div class="category-page__count">{{ header }}</div>
          {% endif %}
        </div>

        <div class="category-page__grid">
          {{ rows }}
        </div>

        {% if pager %}
          <div class="category-page__pager">
            {{ pager }}
          </div>
        {% endif %}
      </div>

    </div>

  </div>
</div>
