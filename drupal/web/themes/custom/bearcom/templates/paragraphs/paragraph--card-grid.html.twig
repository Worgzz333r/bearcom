{# Card Grid — title + subtitle + nested card_item paragraphs #}
{% set style = paragraph.field_style.value|default('default') %}
<section class="card-grid card-grid--cards card-grid--{{ style }}">
  <div class="container">
    {% if paragraph.field_title.value or paragraph.field_subtitle.value %}
      <div class="section__header">
        {% if paragraph.field_title.value %}
          <h2 class="section__title">{{ paragraph.field_title.value }}</h2>
        {% endif %}
        {% if paragraph.field_subtitle.value %}
          <p class="section__subtitle">{{ paragraph.field_subtitle.value }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="card-grid__items">
      {{ content.field_cards }}
    </div>
  </div>
</section>
{{ content|without('field_title', 'field_subtitle', 'field_cards', 'field_style') }}
