{# FAQ Item — accordion question + answer (shared paragraph) #}
<div class="accordion__item">
  <button class="accordion__trigger" aria-expanded="false">
    <span class="accordion__title">{{ paragraph.field_question.value }}</span>
    <span class="accordion__icon" aria-hidden="true">+</span>
  </button>
  <div class="accordion__content">
    <div class="accordion__body">{{ content.field_answer }}</div>
  </div>
</div>
