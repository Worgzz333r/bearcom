{#
/**
 * FAQ Two Column — accordion left, image or map right.
 * If field_image filled → image. Else if lat/lon → map. Else → full width.
 */
#}
{% set has_image = not paragraph.field_image.isEmpty %}
{% set has_map = paragraph.field_latitude.value and paragraph.field_longitude.value %}
{% set has_right = has_image or has_map %}

<section class="faq-two-col">
  <div class="container">
    {% if paragraph.field_title.value %}
      <h2 class="faq-two-col__heading">{{ paragraph.field_title.value }}</h2>
    {% endif %}

    <div class="faq-two-col__layout{{ has_right ? '' : ' faq-two-col__layout--full' }}">
      <div class="faq-two-col__left">
        <div class="accordion">
          {{ content.field_faq }}
        </div>
      </div>

      {% if has_image %}
        <div class="faq-two-col__right">
          <div class="faq-two-col__image">
            {{ content.field_image }}
          </div>
        </div>
      {% elseif has_map %}
        <div class="faq-two-col__right">
          <div class="faq-two-col__map location-detail-map"
               data-lat="{{ paragraph.field_latitude.value }}"
               data-lon="{{ paragraph.field_longitude.value }}"></div>
        </div>
      {% endif %}
    </div>
  </div>
</section>
