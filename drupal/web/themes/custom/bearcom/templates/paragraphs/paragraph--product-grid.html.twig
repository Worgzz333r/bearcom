{# Product Grid — embeds a View by machine name #}
{% set view_id = paragraph.field_view_id.value %}
{% set display_id = 'block_1' %}

<section class="product-grid">
  {% if paragraph.field_title.value %}
    <div class="section__header">
      <h2 class="section__title">{{ paragraph.field_title.value|raw }}</h2>
    </div>
  {% endif %}

  <div class="product-grid__content">
    {{ drupal_view(view_id, display_id) }}
  </div>
</section>
{{ content|without('field_view_id', 'field_title', 'field_limit') }}
