{# Card Item — image + top title + main title + subtitle #}
{% set has_text = paragraph.field_title.value or paragraph.field_subtitle.value or paragraph.field_description.value %}
<div class="card {{ not has_text ? 'card--image-only' }}">
  {% if paragraph.field_icon.entity %}
    <div class="card__image">
      {{ content.field_icon }}
    </div>
  {% endif %}

  {% if has_text %}
    <div class="card__body">
      {% if paragraph.field_title.value %}
        <span class="card__top-title">{{ paragraph.field_title.value }}</span>
      {% endif %}

      {% if paragraph.field_subtitle.value %}
        <h3 class="card__main-title">{{ paragraph.field_subtitle.value }}</h3>
      {% endif %}

      {% if paragraph.field_description.value %}
        <span class="card__subtitle">{{ paragraph.field_description.value|striptags|raw }}</span>
      {% endif %}
    </div>
  {% endif %}
</div>
