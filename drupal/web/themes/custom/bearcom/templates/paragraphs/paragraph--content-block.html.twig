{# Content Block — image left/right + caption + title + body #}
{% set layout = paragraph.field_layout.value|default('image-left') %}
{% set is_divided = layout starts with 'divided' %}

<section class="{{ is_divided ? 'content-block--' ~ layout : 'content-block content-block--' ~ layout }}">
  {% if layout != 'centered' %}
    <div class="content-block__wave" aria-hidden="true"></div>
  {% endif %}
  <div class="container">
    <div class="content-block__inner">
      {% if paragraph.field_image.entity %}
        <div class="content-block__image">
          {{ content.field_image }}
        </div>
      {% endif %}

      <div class="content-block__content">
        {% if paragraph.field_subtitle.value %}
          <span class="content-block__caption{{ paragraph.field_uppercase.value ? ' content-block__caption--uppercase' : '' }}">{{ paragraph.field_subtitle.value }}</span>
        {% endif %}

        {% if paragraph.field_title.value %}
          <h2 class="content-block__title">{{ paragraph.field_title.value }}</h2>
        {% endif %}

        {% if paragraph.field_body.value %}
          <div class="content-block__body">{{ content.field_body }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{{ content|without('field_layout', 'field_image', 'field_title', 'field_body', 'field_subtitle', 'field_uppercase', 'field_section_style') }}
