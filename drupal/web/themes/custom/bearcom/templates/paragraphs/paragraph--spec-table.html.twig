{# Spec Table — title + description + rows, 6+ rows collapse into accordion #}
<div class="spec-table">
  {% if paragraph.field_title.value %}
    <h2 class="spec-table__title">{{ paragraph.field_title.value }}</h2>
  {% endif %}

  {% if paragraph.field_description.value %}
    <div class="spec-table__description">{{ content.field_description }}</div>
  {% endif %}

  <div class="spec-table__rows" data-specs>
    {{ content.field_items }}
  </div>
</div>
