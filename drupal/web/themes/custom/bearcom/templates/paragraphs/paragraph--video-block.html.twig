{# Video Block — title + embedded video #}
<section class="video-block">
  <div class="container">
    {% if paragraph.field_title.value %}
      <div class="section__header">
        <h2 class="section__title">{{ paragraph.field_title.value }}</h2>
      </div>
    {% endif %}

    <div class="video-block__player">
      {{ content.field_video }}
    </div>
  </div>
</section>
