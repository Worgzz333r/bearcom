{# Spec Row — label + value + optional tooltip #}
<div class="spec-row">
  <div class="spec-row__label">
    <span class="spec-row__dot"></span>
    <strong>{{ paragraph.field_label.value }}</strong>
    {% if paragraph.field_tooltip.value %}
      <span class="spec-row__tooltip" data-tooltip="{{ paragraph.field_tooltip.value }}">
        <span class="spec-row__tooltip-icon">?</span>
      </span>
    {% endif %}
  </div>
  <div class="spec-row__value">{{ paragraph.field_value.value }}</div>
</div>
