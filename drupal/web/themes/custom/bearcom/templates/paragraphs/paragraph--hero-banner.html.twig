{# Hero Banner — styles: product, image, color, solid #}
{% set style = paragraph.field_style.value|default('image') %}
<section class="hero hero--{{ style }}">
  <div class="container">
    {% if paragraph.field_product_image.entity %}
      <div class="hero__product-image">
        {% set media = paragraph.field_product_image.entity %}
        <img src="/sites/default/files/{{ media.field_media_image.entity.uri.value|replace({'public://': ''}) }}" alt="{{ paragraph.field_title.value }}">
      </div>
    {% endif %}

    <div class="hero__content">
      {% if paragraph.field_title.value %}
        <h1 class="hero__title">{{ paragraph.field_title.value }}</h1>
      {% endif %}

      {% if paragraph.field_subtitle.value %}
        <p class="hero__subtitle">{{ paragraph.field_subtitle.value }}</p>
      {% endif %}

      {% if paragraph.field_cta_url.0.url or paragraph.field_secondary_url.0.url %}
        <div class="hero__buttons">
          {% if paragraph.field_cta_url.0.url %}
            <a href="{{ paragraph.field_cta_url.0.url }}" class="btn btn--primary hero__cta">
              {{ paragraph.field_cta_text.value|default(paragraph.field_cta_url.0.title)|default('Learn More') }}
            </a>
          {% endif %}
          {% if paragraph.field_secondary_url.0.url %}
            <a href="{{ paragraph.field_secondary_url.0.url }}" class="btn btn--outline hero__cta">
              {{ paragraph.field_secondary_url.0.title|default('Learn More') }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>
