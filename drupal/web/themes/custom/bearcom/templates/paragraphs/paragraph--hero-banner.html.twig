{# Hero Banner — 3 styles: product, image, solid color #}
{% set style = paragraph.field_style.value|default('image') %}

<section class="hero hero--{{ style }}" {% if style == 'image' and paragraph.field_image.entity %}style="background-image: url('{{ file_url(paragraph.field_image.entity.field_media_image.entity.uri.value) }}');"{% endif %}>
  <div class="container">
    {# Product style: image LEFT, content RIGHT #}
    {% if style == 'product' and paragraph.field_product_image.entity %}
      <div class="hero__product-image">
        <img src="{{ file_url(paragraph.field_product_image.entity.field_media_image.entity.uri.value) }}" alt="{{ paragraph.field_title.value }}">
      </div>
    {% endif %}

    <div class="hero__content">
      {% if paragraph.field_title.value %}
        <h1 class="hero__title">{{ paragraph.field_title.value }}</h1>
      {% endif %}

      {% if paragraph.field_subtitle.value %}
        <p class="hero__subtitle">{{ paragraph.field_subtitle.value }}</p>
      {% endif %}

      {% if paragraph.field_cta_text.value %}
        <div class="hero__buttons">
          <a href="{{ paragraph.field_cta_url.0.url }}" class="btn btn--primary hero__cta">
            {{ paragraph.field_cta_text.value }}
          </a>
          <a href="{{ paragraph.field_cta_url.0.url }}" class="btn btn--outline hero__cta">
            Secondary Button
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>
