{#
/**
 * Product Comparison — title + subtitle + two cards (white/orange).
 * Uses field_title, field_subtitle, field_items (nested product_comparison_card paragraphs).
 */
#}

<section class="product-comparison">
  <div class="container">
    {% if paragraph.field_title.value or paragraph.field_subtitle.value %}
      <div class="section__header">
        {% if paragraph.field_title.value %}
          <h2 class="section__title">{{ paragraph.field_title.value }}</h2>
        {% endif %}
        {% if paragraph.field_subtitle.value %}
          <p class="section__subtitle">{{ paragraph.field_subtitle.value }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="product-comparison__grid">
      {{ content.field_items }}
    </div>
  </div>
</section>
