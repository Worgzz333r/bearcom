{# Solutions Grid — always renders via Swiper, JS handles grid/slider mode #}
{% set card_count = paragraph.field_cards|length %}
{% set hide_mobile = paragraph.field_hide_mobile.value %}
<section class="solutions-grid{{ hide_mobile ? ' hide-on-mobile' : '' }}" data-card-count="{{ card_count }}">
  <div class="container">
    {% if paragraph.field_title.value or content.field_description|render|trim %}
      <div class="section__header">
        {% if paragraph.field_title.value %}
          <h2 class="section__title">{{ paragraph.field_title.value }}</h2>
        {% endif %}
        {% if content.field_description|render|trim %}
          <div class="section__subtitle">{{ content.field_description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="solutions-grid__items">
      {{ content.field_cards }}
    </div>
  </div>
</section>
{{ content|without('field_cards', 'field_hide_mobile', 'field_title', 'field_description') }}
