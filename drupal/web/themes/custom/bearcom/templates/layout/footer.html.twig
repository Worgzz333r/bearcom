{#
/**
 * @file
 * Site footer — full variant.
 * Content loaded from Drupal menus + bearcom_sync.footer config.
 * Edit: Structure → Menus (footer-*) for navigation.
 * Edit: drush config:edit bearcom_sync.footer for addresses/social/patent.
 */
#}

<footer class="site-footer">
  {# Main footer area #}
  <div class="site-footer__main">
    <div class="container">

      {# Top row: Logo + Social #}
      <div class="site-footer__top-row">
        <a href="/" class="site-footer__logo" aria-label="BearCom Home">
          <img src="/{{ directory }}/images/logo-white-new.svg" alt="BearCom AlwaysOn" width="226" height="76">
        </a>

        {% if footer.social %}
          <div class="site-footer__social">
            {% for social in footer.social %}
              <a href="{{ social.url }}" class="site-footer__social-link" aria-label="{{ social.label }}">
                <span class="site-footer__social-icon"></span>
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {# Content row: Addresses + Menu columns #}
      <div class="site-footer__content">
        {% if footer.addresses %}
          <div class="site-footer__addresses">
            {% for addr in footer.addresses %}
              <div class="site-footer__address">
                <strong class="site-footer__address-title">{{ addr.title }}</strong>
                <p class="site-footer__address-text">{{ addr.address|nl2br }}</p>
                <a href="tel:{{ addr.phone }}" class="site-footer__phone">
                  <img src="/{{ directory }}/images/icon-phone.svg" alt="" width="14" height="14" class="site-footer__phone-icon" aria-hidden="true">
                  {{ addr.phone_display }}
                </a>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if footer_nav %}
          <nav class="site-footer__nav" aria-label="Footer navigation">
            {% for column in footer_nav %}
              <div class="site-footer__column">
                <h4 class="site-footer__column-title">{{ column.title }}</h4>
                <ul class="site-footer__column-list">
                  {% for link in column.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              </div>
            {% endfor %}
          </nav>
        {% endif %}
      </div>

      {# Bottom: Legal links + Patent #}
      <div class="site-footer__bottom">
        {% if footer_legal %}
          <div class="site-footer__legal-links">
            {% for link in footer_legal %}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          </div>
        {% endif %}
        {% if footer.patent %}
          <p class="site-footer__patent">{{ footer.patent }}</p>
        {% endif %}
      </div>

    </div>
  </div>

  {# Soundwave watermark #}
  <div class="site-footer__wave">
    <div class="site-footer__wave-graphic" aria-hidden="true">
      <img src="/{{ directory }}/images/soundwave.svg" alt="" width="291" height="234">
    </div>
  </div>
</footer>
