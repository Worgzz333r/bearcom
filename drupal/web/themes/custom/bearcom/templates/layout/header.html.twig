{#
/**
 * @file
 * Site header: top bar + navigation + mega menu.
 */
#}

{# Top Bar #}
<div class="top-bar">
  <div class="container">
    <div class="top-bar__inner">
      <button class="top-bar__search-icon" aria-label="Search" data-search-toggle>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <div class="top-bar__search-field" data-search-field>
        <form action="/search" method="get">
          <input type="text" name="keys" placeholder="Search..." aria-label="Search">
        </form>
      </div>
      <a href="tel:8005271670" class="top-bar__phone">(800) 527-1670</a>
      <a href="/locations" class="top-bar__locations">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Locations
      </a>
      <div class="top-bar__country-switch">
        <span>US</span> | <span>Canada</span>
      </div>
    </div>
  </div>
</div>

{# Main Header #}
<header class="site-header {{ header_minimal ? 'site-header--minimal' : '' }}">
  <div class="container">
    <div class="site-header__inner">
      <a href="/" class="site-header__logo" aria-label="BearCom Home">
        {# TODO: Replace with actual logo SVG #}
        <span style="font-size: 24px; font-weight: 600; color: var(--color-dark-blue);">BearCom</span>
      </a>

      <nav class="site-header__nav" aria-label="Main navigation">
        {{ drupal_menu('main') }}
        <a href="/contact-us" class="site-header__cta">Contact Us</a>
      </nav>

      <button class="hamburger" aria-label="Open menu" data-mobile-menu-toggle>
        <span class="hamburger__line"></span>
        <span class="hamburger__line"></span>
        <span class="hamburger__line"></span>
      </button>
    </div>
  </div>
</header>
