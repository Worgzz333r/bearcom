{#
/**
 * @file
 * Site header: top bar + navigation + mega menu + mobile menu.
 */
#}

{# Top Bar #}
<div class="top-bar {{ header_minimal ? 'top-bar--hidden' : '' }}">
  <div class="container">
    <div class="top-bar__inner">
      <div class="top-bar__search">
        <div class="top-bar__search-field" data-search-field>
          <form action="/search" method="get">
            <input type="text" name="keys" placeholder="Search..." aria-label="Search">
          </form>
        </div>
        <button class="top-bar__search-icon" aria-label="Search" data-search-toggle>
          <img src="/{{ directory }}/images/seach-icon.svg" width="20" height="20" alt="Search">
        </button>
      </div>
      <div class="top-bar__contact">
        <a href="tel:8005271670" class="top-bar__phone">
          <img src="/{{ directory }}/images/phone.svg" width="20" height="20" alt="">
          (800) 527-1670
        </a>
        <a href="/locations" class="top-bar__locations">
          <img src="/{{ directory }}/images/map.svg" width="20" height="20" alt="">
          Locations
        </a>
      </div>
      <div class="top-bar__country-switch">
        <img src="/{{ directory }}/images/us.svg" width="28" height="20" alt="US">
        <img src="/{{ directory }}/images/ca.svg" width="28" height="20" alt="Canada">
      </div>
    </div>
  </div>
</div>

{# Main Header #}
<header class="site-header {{ header_minimal ? 'site-header--minimal' : '' }}">
  <div class="container">
    <div class="site-header__inner">
      {% if header_minimal %}
        <a href="/" class="site-header__logo site-header__logo--text" aria-label="BearCom Home">
          {{ header_minimal_title|default('BearCom') }}
        </a>
      {% else %}
        <a href="/" class="site-header__logo" aria-label="BearCom Home">
          <img src="/{{ directory }}/images/bearcom-logo.png" alt="BearCom - Always On">
        </a>
      {% endif %}

      <nav class="site-header__nav" aria-label="Main navigation">
        {{ drupal_menu('main', 1, 0, true) }}
        <a href="/contact-us" class="btn btn--primary site-header__cta">Contact Us</a>
      </nav>

      {% if header_minimal %}
        <a href="/contact-us" class="btn btn--primary site-header__cta site-header__cta--minimal">Contact Us</a>
      {% endif %}

      <div class="site-header__mobile-actions">
        <div class="site-header__mobile-search-wrap" data-mobile-search>
          <button class="site-header__mobile-search" aria-label="Search" data-mobile-search-toggle>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 19L14.9389 14.9389M17.1111 9.55556C17.1111 13.7284 13.7284 17.1111 9.55556 17.1111C5.38274 17.1111 2 13.7284 2 9.55556C2 5.38274 5.38274 2 9.55556 2C13.7284 2 17.1111 5.38274 17.1111 9.55556Z" stroke="#22262C" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <form class="site-header__mobile-search-field" action="/search" method="get">
            <input type="text" name="keys" placeholder="Search..." aria-label="Search">
          </form>
        </div>
        <button class="hamburger" aria-label="Open menu" data-mobile-menu-toggle>
          <svg class="hamburger__icon-menu" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 10H19M1 16H19M1 4H19" stroke="#22262C" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="hamburger__icon-close" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L19 19M19 1L1 19" stroke="#22262C" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

{# Mobile Menu — slides under header #}
<div class="mobile-menu" data-mobile-menu>
  {# Secondary bar #}
  <div class="mobile-menu__bar">
    <div class="mobile-menu__bar-left">
      <a href="tel:8005271670" class="mobile-menu__bar-item" aria-label="Call">
        <img src="/{{ directory }}/images/phone.svg" width="18" height="18" alt="">
      </a>
      <a href="/locations" class="mobile-menu__bar-item" aria-label="Locations">
        <img src="/{{ directory }}/images/map.svg" width="18" height="18" alt="">
      </a>
    </div>
    <div class="mobile-menu__bar-right">
      <span class="mobile-menu__bar-item">
        <img src="/{{ directory }}/images/us.svg" width="30" height="18" alt="US">
      </span>
      <span class="mobile-menu__bar-item">
        <img src="/{{ directory }}/images/ca.svg" width="30" height="18" alt="Canada">
      </span>
    </div>
  </div>

  {# Accordion nav — rendered from same Drupal menu #}
  <nav class="mobile-menu__nav" aria-label="Mobile navigation">
    {% set menu_tree = drupal_menu('main', 1, 0, true) %}
    {{ menu_tree }}
  </nav>

  {# Bottom CTA block #}
  <div class="mobile-menu__cta">
    <a href="/about" class="mobile-menu__cta-link">
      <strong>Bearcom overview &rsaquo;</strong>
      <span class="mobile-menu__cta-desc">Learn how Bearcom's 70 locations and 1,100+ Employees can help you with your voice, security and data needs.</span>
    </a>
    <hr class="mobile-menu__cta-hr">
    <a href="/contact-us" class="mobile-menu__cta-link">
      <strong>Request a quote &rsaquo;</strong>
      <span class="mobile-menu__cta-desc">Talk to our Expert Consultant today.</span>
    </a>
    <hr class="mobile-menu__cta-hr">
    <a href="/contact-us" class="mobile-menu__cta-link">
      <strong>Request a consultation &rsaquo;</strong>
      <span class="mobile-menu__cta-desc">Not sure which product is right for you, we'll guide you to the right solution.</span>
    </a>
  </div>
</div>
